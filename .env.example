# =============================================================================
# sla-marketplace — environment
#
# Copy to .env, fill in, NEVER commit.
# =============================================================================

# Deployer / test wallet private key (0x-prefixed hex)
# Use a throwaway testnet wallet — NOT your main wallet
PRIVATE_KEY=

# Arc Testnet RPC
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Deployed contract addresses (filled in after deploy)
USDC_ADDRESS=0x3600000000000000000000000000000000000000
SERVICE_REGISTRY_ADDRESS=
PAY_PER_CALL_ADDRESS=
